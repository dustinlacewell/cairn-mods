---
import Layout from "../components/Layout.astro";
import { mods, kindLabel } from "../data/mods";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const players = mods.filter((m) => m.kind === "player");
const libs = mods.filter((m) => m.kind !== "player");
---

<Layout title="Cairn mods" description="Mods for Cairn, built on MelonLoader." active="home">
  <section class="wrap page">
    <h1>Cairn mods</h1>
    <p class="intro dim">
      A collection of mods for <span class="green">Cairn</span>, built on MelonLoader.
      <a href={`${base}/install/`}>Install MelonLoader</a> once, then drop in the <code>.dll</code>s you
      want.
    </p>

    <div class="listing">
      {
        players.map((m) => (
          <a class="row" href={`${base}/mods/${m.slug}/`}>
            <span class="name mono">{m.name}</span>
            <span class="dim desc">{m.tagline}</span>
          </a>
        ))
      }
    </div>

    <p class="label section">Libraries</p>
    <div class="listing">
      {
        libs.map((m) => (
          <a class="row" href={`${base}/mods/${m.slug}/`}>
            <span class="name mono">{m.name}</span>
            <span class={`kind ${m.kind}`}>{kindLabel[m.kind]}</span>
            <span class="dim desc">{m.tagline}</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .page {
    padding-top: 2.5rem;
  }
  h1 {
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
  }
  .intro {
    margin-bottom: 2rem;
    max-width: 62ch;
  }
  .listing {
    margin-bottom: 1.5rem;
  }
  .row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    color: var(--text);
    padding: 0.3rem 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .row:last-child {
    border-bottom: none;
  }
  .row:hover {
    text-decoration: none;
    background: var(--surface);
  }
  .name {
    color: var(--text);
    font-size: 13px;
    min-width: 11rem;
    flex-shrink: 0;
  }
  .row:hover .name {
    color: var(--accent);
  }
  .desc {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 13px;
  }
  .section {
    margin: 0.5rem 0 0.75rem;
  }
  @media (max-width: 560px) {
    .desc {
      display: none;
    }
  }
</style>
