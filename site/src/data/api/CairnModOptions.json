    {
      "id": "modoption",
      "title": "ModOption",
      "intro": "Build each row with a ModOption factory. Every option takes a label and an optional tooltip. Stateful options (toggle, slider, text, list, dropdown) bind either to a MelonPreferences entry — persisted to disk automatically — or to your own get/set callbacks.",
      "code": {
        "lang": "csharp",
        "src": "// backed by a MelonPreferences entry (persists to disk)\nModOption.Toggle(\"Enable\", enabledEntry);\n\n// or your own get/set\nModOption.Toggle(\"Enable\",\n    () => _enabled, v => _enabled = v);\n\n// numeric-only text field\nModOption.TextField(\"Max count\", maxEntry,\n    TMP_InputField.ContentType.IntegerNumber);\n\n// a non-persistent action button\nModOption.Action(\"Reload config\", ReloadConfig);"
      },
      "entries": [
        {
          "signature": "ModOption.Toggle(label, entry, tooltip?)",
          "returns": "ModOption",
          "description": "Bool on/off. Backed by a MelonPreferences_Entry<bool>, or a Func<bool> get / Action<bool> set pair.",
          "params": [
            {
              "name": "label",
              "type": "string",
              "description": "Row label."
            },
            {
              "name": "entry",
              "type": "MelonPreferences_Entry<bool>",
              "description": "Backing preference (or pass get/set callbacks)."
            },
            {
              "name": "tooltip",
              "type": "string",
              "description": "Hover help.",
              "optional": true
            }
          ]
        },
        {
